# OpenRouter API Key for fallback/free models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key for fast inference and embeddings
GROQ_API_KEY=your_groq_api_key_here

# Provider-swappable scraper configurations (e.g., if using rapidapi or custom scraper)
SCRAPER_API_KEY=your_scraper_api_key_here
SCRAPER_PROVIDER=instagram-scraper # e.g. rapidapi, local, custom
