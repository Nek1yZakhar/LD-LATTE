# OpenRouter API Key for fallback/free models
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key for fast inference
GROQ_API_KEY=your_groq_api_key_here

# Local Model Configurations
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
LOCAL_MODELS_CACHE_DIR=./models/cache

# LLM Client Model Configurations
GROQ_DEFAULT_MODEL=llama3-8b-8192
OPENROUTER_DEFAULT_MODEL=qwen/qwen-2.5-7b-instruct:free

# Provider-swappable scraper configurations (e.g., if using rapidapi or custom scraper)
SCRAPER_API_KEY=your_scraper_api_key_here
SCRAPER_PROVIDER=instagram-scraper # e.g. rapidapi, local, custom
